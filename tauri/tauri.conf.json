{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gsein-war3",
  "version": "0.1.0",
  "identifier": "com.gsein.war3",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "gsein-war3",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "resources": {
      "../clojure/target/gsein-war3-0.1.0-SNAPSHOT-standalone.jar": "gsein-war3.jar"
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
